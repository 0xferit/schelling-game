{
  "name": "schelling-game",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "npx wrangler dev",
    "dev": "npx wrangler dev",
    "test": "vitest run",
    "test:worker": "vitest run --config vitest.config.worker.ts",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "typecheck:worker": "tsc --noEmit -p tsconfig.worker.json",
    "stamp-build": "sed -i.bak -e \"s/__BUILD_HASH__/$(git rev-parse --short HEAD)/\" -e \"s/__BUILD_DATE__/$(date -u +%Y-%m-%dT%H:%MZ)/\" public/index.html public/app.html",
    "unstamp-build": "mv public/index.html.bak public/index.html && mv public/app.html.bak public/app.html",
    "deploy": "npm run stamp-build && CLOUDFLARE_API_TOKEN=${CLOUDFLARE_FERIT_API_TOKEN:-$CLOUDFLARE_API_TOKEN} npx wrangler deploy && npm run unstamp-build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/proveuswrong/schelling-game.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/proveuswrong/schelling-game/issues"
  },
  "homepage": "https://github.com/proveuswrong/schelling-game#readme",
  "dependencies": {
    "ethers": "^6.16.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@cloudflare/vitest-pool-workers": "^0.13.4",
    "@cloudflare/workers-types": "^4.20260317.1",
    "@vitest/coverage-v8": "^4.1.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
